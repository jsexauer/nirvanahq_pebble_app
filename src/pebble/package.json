{
  "name": "pebble",
  "author": "MakeAwesomeHappen",
  "version": "1.0.0",
  "keywords": [
    "pebble-app"
  ],
  "private": true,
  "dependencies": {
    "pebble-clay": "^1.0.3"
  },
  "pebble": {
    "displayName": "NirvanaHQ",
    "uuid": "e56ef65e-c519-48b7-9a8e-03122f474867",
    "sdkVersion": "3",
    "enableMultiJS": true,
    "targetPlatforms": [
      "aplite",
      "basalt",
      "chalk",
      "diorite",
      "emery"
    ],
    "watchapp": {
      "watchface": false
    },
    "capabilities": [
      "voice"
    ],
    "messageKeys": [
      "AppKeyReady",
      "AppKeyRequestTasks",
      "AppKeyTaskCount",
      "AppKeyTaskIndex",
      "AppKeyTaskName",
      "AppKeyTaskState",
      "AppKeyCreateTask",
      "AppKeyInitiateTaskCreation",
      "AppKeyStartDictation",
      "AppKeyTaskCreatedSuccess",
      "AppKeyAreaCount",
      "AppKeyAreaIndex",
      "AppKeyAreaName",
      "AppKeyFilterType",
      "AppKeyFilterTag",
      "AppKeyTaskId",
      "AppKeyTaskNote",
      "AppKeyTaskDueDate",
      "AppKeyTaskTags",
      "AppKeyTaskAreas",
      "AppKeyTaskProject",
      "AppKeyTaskDetail",
      "AppKeyTaskFocus",
      "AppKeyCompleteTask",
      "AppKeyRenameTask",
      "AppKeyEditNote",
      "AppKeyEditArea",
      "AppKeyEditTags",
      "AppKeyEditProject",
      "AppKeyChangeTaskState",
      "AppKeyRequestList",
      "AppKeyListType",
      "AppKeyListCount",
      "AppKeyListIndex",
      "AppKeyListItemName",
      "AppKeyListItemId"
    ],
    "resources": {
      "media": [
        {
          "type": "png",
          "name": "IMAGE_MENU_ICON",
          "file": "images/menu_icon.png",
          "menuIcon": true
        },
        {
          "type": "bitmap",
          "name": "ACTION_COMPLETE",
          "file": "images/action_complete.png"
        },
        {
          "type": "bitmap",
          "name": "ACTION_EDIT",
          "file": "images/action_edit.png"
        },
        {
          "type": "bitmap",
          "name": "ACTION_STATUS",
          "file": "images/action_status.png"
        }
      ]
    }
  }
}