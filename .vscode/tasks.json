{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run Pebble Emulator",
            "type": "shell",
            "command": ".\\src\\pebble\\run_emulator.ps1",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "close": true
            },
            "group": {
                "kind": "test",
                "isDefault": true
            }
        },
        {
            "label": "Hard Reset Pebble Emulator",
            "type": "shell",
            "command": ".\\src\\pebble\\run_emulator_hard_reset.ps1",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "close": false
            },
            "group": "test"
        },
        {
            "label": "Build Pebble App",
            "type": "shell",
            "command": "wsl ~/.local/bin/pebble build",
            "options": {
                "cwd": "${workspaceFolder}/src/pebble"
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}